###############################################
# Hybrid AI Agent – Environment Template (v5)
#
# Copy this file to ".env" and fill in the values.
# The Python code should load it via config/settings.py.
###############################################

###########
# Runtime #
###########

AGENT_ENV=dev
LOG_LEVEL=INFO

# Root directory of the project (defaults to directory of scaffold.py if unset)
HYBRID_AGENT_ROOT=E:\ui-agent

# Which monitor to use for automation (1 = first/left, 2 = middle, 3 = right, etc.)
PRIMARY_MONITOR=2

#################
# Model Providers
#################

# Claude (Anthropic) – used for planner_task (Sonnet) and planner_execution (Haiku)
# Sign up at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Default Claude models to use for the two planners
ANTHROPIC_TASK_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_EXECUTION_MODEL=claude-3-haiku-20240307

# Gemini – used for level5_cloud_vision (desktop/vision). Sign up at: https://ai.google.dev
# Valid models: gemini-3-flash-preview, gemini-2.5-flash, gemini-2.0-flash
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_VISION_MODEL=gemini-3-flash-preview

# Qwen2-VL – local or cloud VLM for level4_local_vision
# If using an HTTP endpoint, configure URL + API key.
QWEN_VL_ENDPOINT=http://localhost:8000/v1/chat/completions
QWEN_VL_API_KEY=your_qwen_api_key_here
QWEN_VL_MODEL=qwen2-vl-72b-instruct

###########################
# Persistence + File Paths
###########################

# SQLite DB for trajectory store and safety/action logging
TRAJECTORY_DB_PATH=E:\ui-agent\storage\trajectory.db
ACTION_LOG_DB_PATH=E:\ui-agent\storage\actions.db

# OpenCV template directory (TemplateMatchingConfig.template_dir)
TEMPLATE_DIR=E:\ui-agent\templates

# Safety backup locations (from .cursorrules Safety Rules)
AGENT_TRASH_DIR=C:\.agent_trash
AGENT_BACKUP_DIR=C:\.agent_backups
AGENT_REG_BACKUP_DIR=C:\.agent_reg_backups

#########################
# Browser / Playwright  #
#########################

# If you pin a specific browser channel or executable, configure here.
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_HEADLESS=true

########################
# Timeouts & Budgets   #
########################

# Global per-action timeout in seconds
ACTION_TIMEOUT_SECONDS=60

# Per-run governance budgets (soft limits)
MAX_STEPS_PER_RUN=200
MAX_SECONDS_PER_RUN=1800
MAX_LLM_TOKENS_PER_RUN=200000

########################
# Misc Feature Flags   #
########################

# Enable sandbox mode by default (no real destructive actions)
SANDBOX_MODE=true

# Enable verbose debug logging for latency profiler and trajectory stores
ENABLE_LATENCY_DEBUG=false
ENABLE_TRAJECTORY_DEBUG=false

