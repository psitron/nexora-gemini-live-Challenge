node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# DynamoDB local
.dynamodb/

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# Temporary files
*.tmp
*.bak
.cache/

# AWS credentials (shouldn't be in repo)
credentials
config
