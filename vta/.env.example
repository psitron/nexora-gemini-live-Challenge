# VTA Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Google Gemini Configuration
# ============================================================================

# Gemini API Key (required)
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud Project (for GCE deployment)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Gemini Computer Use model (for vision-driven tasks)
# GEMINI_COMPUTER_USE_MODEL=gemini-2.0-flash

# ============================================================================
# Service Ports
# ============================================================================

# Agent S3 REST API port
AGENT_S3_PORT=5001

# Task Orchestrator WebSocket port
ORCHESTRATOR_PORT=5000

# Agent S3 URL (used by orchestrator to call Agent S3)
AGENT_S3_URL=http://localhost:5001

# ============================================================================
# Virtual Display Configuration (Linux only)
# ============================================================================

# X Display for Xvfb
DISPLAY=:1

# Virtual display dimensions
VTA_DISPLAY_WIDTH=1280
VTA_DISPLAY_HEIGHT=800

# ============================================================================
# Development Settings
# ============================================================================

# Use local JSON files instead of cloud storage (for dev/testing)
VTA_LOCAL_CURRICULUM=true
VTA_LOCAL_STATE=true

# Brain model selection: "flash" (fast) or "pro" (capable)
VTA_BRAIN_MODEL=flash

# Execution mode: demo_only, follow_along, follow_along_paced
# VTA_EXECUTION_MODE=demo_only

# Python path (if running from project root)
# PYTHONPATH=/opt/vta

# ============================================================================
# Logging
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# Frontend Configuration
# ============================================================================

# PDF storage (local path)
# VTA_PDF_BUCKET=vta-tutorial-pdfs

# API base URL (for PDF serving)
# VTA_API_BASE_URL=http://localhost:5000

# ============================================================================
# Security (Production only)
# ============================================================================

# Enable authentication (not implemented yet)
# VTA_ENABLE_AUTH=false

# JWT secret (if auth enabled)
# VTA_JWT_SECRET=your-secret-key-here

# CORS allowed origins (comma-separated)
# VTA_CORS_ORIGINS=http://localhost:3000,https://your-domain.com
